# ---- Gemini ----
# The service supports THREE modes:
#   1) STUB         : neither GEMINI_API_KEY nor GOOGLE_GENAI_USE_VERTEXAI set.
#                     Deterministic offline response. Useful for tests / CI.
#   2) API key      : GEMINI_API_KEY set. Uses the Gemini Developer API.
#                     NOTE: Cloud Run / Agent Platform security policy disallows
#                     raw API keys, so this mode is for local dev only.
#   3) Vertex AI    : GOOGLE_GENAI_USE_VERTEXAI=true. Uses Application Default
#                     Credentials (no API key). This is the Cloud Run mode.
GEMINI_API_KEY=
# Model is ALWAYS read from env. Never hardcoded in code.
# Confirm the current model id in Google's docs before deploying.
GEMINI_MODEL=gemini-2.5-flash

# ---- Vertex AI (Gemini on Google Cloud, via ADC) ----
# Set GOOGLE_GENAI_USE_VERTEXAI=true on Cloud Run to call Gemini through
# Vertex AI with the runtime service account. The google-genai SDK reads these
# three env vars directly.
#
# IMPORTANT: GOOGLE_CLOUD_PROJECT is for Vertex AI ONLY. It does NOT enable
# Firestore. Firestore is gated separately by GCP_PROJECT (see below) so you
# can run Vertex AI with evidence logs still going to local JSONL.
GOOGLE_GENAI_USE_VERTEXAI=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# ---- Google Cloud (optional, for Firestore evidence log) ----
# Firestore is enabled ONLY when GCP_PROJECT is set (and the firestore client
# library is available). GOOGLE_CLOUD_PROJECT above is intentionally NOT used
# here — leaving GCP_PROJECT empty keeps evidence logging on local JSONL under
# data/runs/ even when Vertex AI is active.
GCP_PROJECT=
GCS_BUCKET=
FIRESTORE_COLLECTION_RUNS=agent_runs

# ---- Data sources ----
# REPORT_SOURCE: synthetic | http | dbview  (only 'synthetic' implemented; others are TODO)
REPORT_SOURCE=synthetic
REPORT_FIXTURE_DIR=data/fixtures

# Path to the LynkMesh context pack used to ground the model.
LYNKMESH_PACK_PATH=data/context_packs/sample_context_pack.json

# ---- Local storage ----
RUNS_DIR=data/runs

# ---- Deployment label (cosmetic; surfaced on /version) ----
# Examples: local, cloud-run-stub, cloud-run-vertex-gemini
APP_ENV=local

# ---- Structured Cloud Logging ----
# When true (default), the service emits sanitized JSON evidence events to
# stdout/stderr so Cloud Run / Cloud Logging captures them as structured
# operational evidence. No prompt text, raw report data, or full Gemini
# responses are emitted. Set to false/0/no to disable.
STRUCTURED_CLOUD_LOGGING_ENABLED=true
